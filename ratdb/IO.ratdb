"include_digitizerwaveforms": false,
"include_untriggered_events": true,
"include_mchits": true,
"include_calib": false,

"event_fitters": ["Bonsai"],
"event_fitter_FOM_Bonsai": ["n9","energy","time","validpostion","validdirection","validenergy","validtime"]

}
