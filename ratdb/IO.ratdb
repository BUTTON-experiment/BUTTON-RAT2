{
"name": "IO",
"index": "NtupleProc",
"run_range": [0, 0],

"default_output_filename": "output.ntuple.root",
"include_tracking": false,
"include_mcparticles": false,
"include_pmthits": true,
"include_nestedtubehits": false,
"include_digitizerhits": true,
